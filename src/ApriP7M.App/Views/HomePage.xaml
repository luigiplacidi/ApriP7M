<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ApriP7M.App.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:ApriP7M.App.ViewModels"
    xmlns:controls="using:ApriP7M.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="PrivacyBandBackgroundBrush" Color="#DFF6E6" />
                    <SolidColorBrush x:Key="PrivacyBandForegroundBrush" Color="#0F6B3A" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="PrivacyBandBackgroundBrush" Color="#123322" />
                    <SolidColorBrush x:Key="PrivacyBandForegroundBrush" Color="#A8F0C1" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast">
                    <SolidColorBrush x:Key="PrivacyBandBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                    <SolidColorBrush x:Key="PrivacyBandForegroundBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <VisualStateManager.VisualStateGroups>
        <VisualStateGroup>
            <VisualState x:Name="WideLayout" />
            <VisualState x:Name="NarrowLayout">
                <VisualState.StateTriggers>
                    <AdaptiveTrigger MinWindowWidth="0" />
                </VisualState.StateTriggers>
                <VisualState.Setters>
                    <Setter Target="DashboardColumn2.Width" Value="0" />
                    <Setter Target="DashboardColumn3.Width" Value="0" />
                    <Setter Target="DashboardRow2.Height" Value="170" />
                    <Setter Target="DashboardRow3.Height" Value="170" />
                    <Setter Target="ConvertActionButton.(Grid.Row)" Value="1" />
                    <Setter Target="ConvertActionButton.(Grid.Column)" Value="0" />
                    <Setter Target="HistoryActionButton.(Grid.Row)" Value="2" />
                    <Setter Target="HistoryActionButton.(Grid.Column)" Value="0" />
                    <Setter Target="OpenAsideColumn.Width" Value="0" />
                    <Setter Target="OpenAsidePanel.(Grid.Row)" Value="1" />
                    <Setter Target="OpenAsidePanel.(Grid.Column)" Value="0" />
                    <Setter Target="OpenRow2.Height" Value="Auto" />
                    <Setter Target="ConvertAsideColumn.Width" Value="0" />
                    <Setter Target="ConvertNote.(Grid.Row)" Value="1" />
                    <Setter Target="ConvertNote.(Grid.Column)" Value="0" />
                    <Setter Target="ConvertRow2.Height" Value="Auto" />
                </VisualState.Setters>
            </VisualState>
            <VisualState x:Name="DefaultLayout">
                <VisualState.StateTriggers>
                    <AdaptiveTrigger MinWindowWidth="1400" />
                </VisualState.StateTriggers>
            </VisualState>
        </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>

    <Grid Padding="28,24,28,0" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer x:Name="PageScrollViewer" Grid.Row="0">
            <StackPanel Spacing="18">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="6">
                        <TextBlock x:Name="HeaderTitle"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="HeaderSubtitle"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                </Grid>

                <Grid x:Name="DashboardSection"
                      ColumnSpacing="14"
                      RowSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition x:Name="DashboardColumn2" Width="*" />
                        <ColumnDefinition x:Name="DashboardColumn3" Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="170" />
                        <RowDefinition x:Name="DashboardRow2" Height="0" />
                        <RowDefinition x:Name="DashboardRow3" Height="0" />
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Grid.Column="0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Click="OpenSection_Click">
                        <StackPanel Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE8E5;"
                                      FontSize="42"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <TextBlock Text="Apri file"
                                       HorizontalAlignment="Center"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="Estrai il documento originale da P7M, PDF, XML e ZIP"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="ConvertActionButton"
                            Grid.Row="0" Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Click="ConvertSection_Click">
                        <StackPanel Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE8A5;"
                                      FontSize="42"
                                      Foreground="#3B82F6" />
                            <TextBlock Text="Converti XML"
                                       HorizontalAlignment="Center"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="Fatture elettroniche XML in PDF leggibile"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="HistoryActionButton"
                            Grid.Row="0" Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Click="HistorySection_Click">
                        <StackPanel Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE81C;"
                                      FontSize="42"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <TextBlock Text="Cronologia"
                                       HorizontalAlignment="Center"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="Riapri i documenti aperti da quando hai avviato l'app"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Button>
                </Grid>

                <controls:SupportProjectCard x:Name="HomeSupportCard" />

                <Border x:Name="OpenSection"
                        AllowDrop="True"
                        DragOver="DropZone_DragOver"
                        Drop="DropZone_Drop"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="32"
                        MinHeight="260">
                    <Grid ColumnSpacing="28" RowSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition x:Name="OpenAsideColumn" Width="260" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition x:Name="OpenRow2" Height="0" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Column="0" Spacing="14" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE8E5;"
                                      FontSize="44"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <TextBlock Text="Trascina qui un file oppure scegli dal PC"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="Un file .p7m è una busta firmata: Apri P7M estrae il documento contenuto dentro e lo mostra, senza caricarlo online."
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <Button Content="Scegli file"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Click="ChooseFile_Click" />
                        </StackPanel>
                        <StackPanel x:Name="OpenAsidePanel" Grid.Column="1" Spacing="10" VerticalAlignment="Center">
                            <TextBlock Text="Cosa succede dopo?"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="Vedrai una schermata di anteprima con i pulsanti per salvare il PDF o il documento originale."
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border x:Name="ConvertSection"
                        AllowDrop="True"
                        DragOver="DropZone_DragOver"
                        Drop="DropZone_Drop"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="32"
                        MinHeight="260">
                    <Grid ColumnSpacing="28" RowSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition x:Name="ConvertAsideColumn" Width="280" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition x:Name="ConvertRow2" Height="0" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Column="0" Spacing="14" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE8A5;"
                                      FontSize="44"
                                      Foreground="#3B82F6" />
                            <TextBlock Text="Converti una fattura XML in PDF leggibile"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="Scegli un file .xml o .xml.p7m. Se è una fattura elettronica, Apri P7M genera una copia PDF di cortesia, più comoda da controllare e stampare."
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <Button Content="Scegli XML o P7M"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Click="ChooseFile_Click" />
                        </StackPanel>
                        <InfoBar x:Name="ConvertNote"
                                 Grid.Column="1"
                                 IsOpen="True"
                                 IsClosable="False"
                                 Severity="Informational"
                                 Title="Nota"
                                 Message="Il PDF è solo una copia leggibile. Il documento fiscale resta l'XML originale." />
                    </Grid>
                </Border>

                <InfoBar IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                         Severity="Error"
                         Title="Non sono riuscito ad aprire questo file"
                         Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                         IsClosable="False">
                    <InfoBar.ActionButton>
                        <Button Content="Mostra diagnostica"
                                Visibility="{x:Bind ViewModel.HasDiagnosticPreview, Mode=OneWay}"
                                Click="ShowDiagnostics_Click" />
                    </InfoBar.ActionButton>
                </InfoBar>

                <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                              HorizontalAlignment="Center" />

                <StackPanel x:Name="ResultsSection"
                            Spacing="10"
                            Visibility="Collapsed">
                    <TextBlock Text="Risultati"
                               Style="{StaticResource SubtitleTextBlockStyle}" />
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Results, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ResultItem">
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="14"
                                        Margin="0,0,0,8">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0"
                                                  Glyph="&#xE8A5;"
                                                  FontSize="22"
                                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="{x:Bind DisplayName}"
                                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{x:Bind KindLabel}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <Button Grid.Column="2"
                                                Content="Visualizza"
                                                CommandParameter="{x:Bind}"
                                                Click="PreviewResult_Click" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel x:Name="HistorySection" Spacing="10">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Cronologia"
                                   Style="{StaticResource SubtitleTextBlockStyle}"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Content="Pulisci cronologia"
                                Visibility="{x:Bind ViewModel.HasRecentResults, Mode=OneWay}"
                                Click="ClearHistory_Click" />
                    </Grid>
                    <InfoBar x:Name="EmptyHistoryNotice"
                             IsOpen="True"
                             IsClosable="False"
                             Severity="Informational"
                             Title="Nessun documento recente"
                             Message="La cronologia vive solo finché l'app è aperta: quando la chiudi si svuota da sola. Non salviamo su disco né i nomi dei file né le cartelle." />
                    <ItemsControl x:Name="HistoryList"
                                  ItemsSource="{x:Bind ViewModel.RecentResults, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ResultItem">
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12"
                                        Margin="0,0,0,8">
                                    <Grid ColumnSpacing="10" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0"
                                                  Glyph="&#xE8A5;"
                                                  FontSize="20"
                                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="{x:Bind DisplayName}"
                                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{x:Bind KindLabel}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <Button Grid.Column="2"
                                                Content="Visualizza"
                                                CommandParameter="{x:Bind}"
                                                Click="PreviewResult_Click" />
                                        <Button Grid.Column="3"
                                                CommandParameter="{x:Bind}"
                                                Click="RemoveHistoryItem_Click"
                                                ToolTipService.ToolTip="Rimuovi dalla cronologia"
                                                AutomationProperties.Name="Rimuovi dalla cronologia">
                                            <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1"
                Margin="-28,0,-28,0"
                Padding="24,10"
                Background="{ThemeResource PrivacyBandBackgroundBrush}">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE72E;"
                          Foreground="{ThemeResource PrivacyBandForegroundBrush}" />
                <TextBlock Text="I tuoi documenti restano sempre sul tuo PC. Nessun upload. Nessuna raccolta dati."
                           Foreground="{ThemeResource PrivacyBandForegroundBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
