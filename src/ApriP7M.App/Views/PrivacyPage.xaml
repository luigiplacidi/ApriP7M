<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ApriP7M.App.Views.PrivacyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:ApriP7M.App.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="16" MaxWidth="760" HorizontalAlignment="Left">
            <TextBlock Text="Privacy" Style="{StaticResource TitleTextBlockStyle}" />

            <InfoBar IsOpen="True" IsClosable="False" Severity="Success"
                     Title="I tuoi documenti restano sul tuo PC"
                     Message="Apri P7M non carica nulla online: tutto avviene sul tuo computer, anche senza internet." />

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Cosa NON facciamo" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock TextWrapping="Wrap" Text="• Nessun file viene caricato online" />
                    <TextBlock TextWrapping="Wrap" Text="• Nessuna telemetria automatica" />
                    <TextBlock TextWrapping="Wrap" Text="• Nessun tracciamento dei documenti" />
                    <TextBlock TextWrapping="Wrap" Text="• Nessun login, nessun account" />
                    <TextBlock TextWrapping="Wrap" Text="• Nessun servizio in background, nessun avvio con Windows" />
                    <TextBlock TextWrapping="Wrap" Text="• Diagnostica anonima solo manuale e solo se attivata" />
                </StackPanel>
            </Border>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="File temporanei e note tecniche" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock TextWrapping="Wrap"
                               Text="I file temporanei restano sul tuo PC e vengono eliminati al termine. Le note tecniche (i cosiddetti log) sono ridotte al minimo e non contengono mai il contenuto dei documenti, i nomi dei file o le cartelle." />
                </StackPanel>
            </Border>

            <controls:SupportProjectCard />
        </StackPanel>
    </ScrollViewer>
</Page>
